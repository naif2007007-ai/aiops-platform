{
  "Version": "2012-10-17",
  "Comment": "Minimum IAM permissions for the AI-Ops Platform App Runner task role",
  "Statement": [
    {
      "Sid": "S3ReadWriteAIOps",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::aiops-platform-poc",
        "arn:aws:s3:::aiops-platform-poc/*"
      ]
    },
    {
      "Sid": "ECRImagePull",
      "Effect": "Allow",
      "Action": [
        "ecr:GetDownloadUrlForLayer",
        "ecr:BatchGetImage",
        "ecr:GetAuthorizationToken"
      ],
      "Resource": "*"
    }
  ]
}
